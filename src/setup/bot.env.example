# bot.env — Telegram bot secrets for picoclaw-telegram.service
# Copy this file to /home/stas/.picoclaw/bot.env on the device
# and fill in the real values from .credentials/.pico_env

BOT_TOKEN=<your_telegram_bot_token_from_botfather>
ALLOWED_USER=<your_telegram_chat_id>

# Nextcloud remote backup (§6.3.3)
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=<nextcloud_username>
NEXTCLOUD_PASS=<nextcloud_app_password>
NEXTCLOUD_REMOTE=/MicoBackups
