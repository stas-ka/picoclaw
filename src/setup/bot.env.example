# bot.env — Telegram bot secrets for picoclaw-telegram.service
# Copy this file to /home/stas/.picoclaw/bot.env on the device
# and fill in the real values from .credentials/.pico_env

BOT_TOKEN=<your_telegram_bot_token_from_botfather>
ALLOWED_USER=<your_telegram_chat_id>

# LLM provider: taris (default) | openclaw | openai | yandexgpt | gemini | anthropic | local
# LLM_PROVIDER=taris

# OpenClaw AI gateway (optional — Feature §4.2)
# Enable on machines where OpenClaw is installed; falls back to taris on Pi.
# OPENCLAW_BIN=~/.local/bin/openclaw
# OPENCLAW_SESSION=taris
# OPENCLAW_TIMEOUT=60

# Internal API token for skill-taris (sintaris-openclaw → Taris /api/* routes)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# TARIS_API_TOKEN=

# Nextcloud remote backup (§6.3.3)
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=<nextcloud_username>
NEXTCLOUD_PASS=<nextcloud_app_password>
NEXTCLOUD_REMOTE=/MicoBackups

# Cloud deploy server — used by update_from_cloud.sh
# CLOUD_DEPLOY_URL  Base URL served by the web server on cloud.dev2null.de
# CLOUD_DEPLOY_TOKEN  Optional Bearer token if the endpoint is protected
CLOUD_DEPLOY_URL=https://cloud.dev2null.de/picoclaw
CLOUD_DEPLOY_TOKEN=
